POSTGRES_URL=postgres://user:pass@localhost:5432/connectpro
REDIS_URL=redis://localhost:6379

# Primary MCP bridge
CONNECTPRO_MCP_BRIDGE_URL=
CONNECTPRO_MCP_BRIDGE_TOKEN=
CONNECTPRO_MCP_COMMAND=
CONNECTPRO_MCP_ARGS=[]

# Primary inbox bridge
CONNECTPRO_INBOX_BRIDGE_SEARCH_URL=
CONNECTPRO_INBOX_BRIDGE_READ_URL=
CONNECTPRO_INBOX_BRIDGE_TOKEN=
CONNECTPRO_INBOX_COMMAND=
CONNECTPRO_INBOX_ARGS=[]

# Optional local fixtures for development/tests
CONNECTPRO_MCP_FIXTURE_PATH=
CONNECTPRO_INBOX_FIXTURE_PATH=

# Operational behavior
CONNECTPRO_ALLOW_MOCK_FALLBACK=false
PORT=3001
CONNECTPRO_CHROME_DEBUG_URL=http://127.0.0.1:9222
